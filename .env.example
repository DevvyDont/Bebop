BOT_TOKEN=
GUILD_ID=
COMMAND_PREFIX=!
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=bebop
LOG_LEVEL=INFO

# Queue settings
# Number of players required to create one match.
QUEUE_SIZE=12
# Optional: force queue message channel ID.
QUEUE_CHANNEL_ID=
# Optional: force slash command channel ID.
COMMANDS_CHANNEL_ID=
# Role name that can run admin queue commands.
ADMIN_ROLE_NAME=PUG Manager

# Deadlock API settings
DEADLOCK_API_BASE_URL=https://api.deadlock-api.com
DEADLOCK_API_KEY=
DEADLOCK_API_TIMEOUT_SECONDS=10
DEADLOCK_CUSTOM_GAME_MODE=normal
# Example: us_east, europe
DEADLOCK_CUSTOM_SERVER_REGION=
DEADLOCK_CUSTOM_DISABLE_AUTO_READY=false
DEADLOCK_CUSTOM_IS_PUBLICLY_VISIBLE=false
# Leave blank to default to half the queue size.
DEADLOCK_CUSTOM_MIN_ROSTER_SIZE=

# Deadlock callback settings
# Enable callback receiver and provide a publicly reachable base URL.
DEADLOCK_CALLBACK_ENABLED=false
DEADLOCK_CALLBACK_PUBLIC_BASE_URL=
DEADLOCK_CALLBACK_BIND_HOST=0.0.0.0
DEADLOCK_CALLBACK_BIND_PORT=8080
DEADLOCK_CALLBACK_PATH_PREFIX=/callbacks/deadlock
DEADLOCK_CALLBACK_AUTO_LEAVE_ENABLED=true
# Leave spectator when observed lobby players reaches this count.
DEADLOCK_CALLBACK_AUTO_LEAVE_MIN_PLAYERS=12
DEADLOCK_CALLBACK_AUTO_LEAVE_RETRY_COOLDOWN_SECONDS=30

